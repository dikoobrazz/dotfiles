[colors]

;background = #2f343f
;background = #08090a
background = #1d1d1d

;background-alt = #4f545f
background-alt = #1a1a1a
foreground = #d8dee8
foreground-old = #787e68
foreground-alt = #009688
accent = #81a1c1
alert = #ebcb8b


[bar/top]

monitor = eDP1
height = 34
fixed-center = true
background = ${colors.background}
foreground = ${colors.foreground}
padding-left = 4
padding-right = 2
module-margin-left = 2
module-margin-right = 2
font-0 = Noto Sans:pixelsize=10
font-1 = FontAwesome:pixelsize=10
tray-transparent = false
override-redirect = true
tray-offset-x = 0
tray-offset-y = 0
tray-position = right
tray-maxsize = 21
tray-padding = 0
;tray-scale = 1
tray-background = ${colors.background}
wm-restack = bspwm
modules-left = bspwm
modules-center = xwindow
modules-right = xkeyboard wlan battery volume date

scroll-up = bspwm-desknext
scroll-down = bspwm-deskprev


[module/bspwm]

type = internal/bspwm
label-focused = %name%
label-focused-background= ${colors.background-alt}
label-focused-padding = 3
label-occupied = %name%
label-occupied-padding = 3
label-occupied-foreground= ${colors.foreground}
label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 3
label-empty = %name%
label-empty-foreground = ${colors.foreground-alt}
label-empty-padding = 3


[module/xwindow]

type = internal/xwindow
label = %title:0:100:...%
label-foreground = ${colors.foreground-old}

[module/mpd]

type = internal/mpd
;format-online = <icon-prev>  <label-time>  <label-song>  <icon-next>
format-online = <toggle>  <label-song>
;format-online = <label-time>  <label-song>
;icon-prev = ’äĆ
;icon-next = ’äü
icon-play = ’Ćü
icon-pause = ’Ćü
;icon-prev-foreground = ${colors.accent}
;icon-next-foreground = ${colors.accent}
icon-pause-foreground = ${colors.accent}
label-song-maxlen = 45
label-song-ellipsis = true


[module/wlan]

type = internal/network
;interface = wlp3s0
interface = wlan0
interval = 15
format-connected = <ramp-signal>  <label-connected>
;label-connected = %essid%
format-disconnected = <label-disconnected>
